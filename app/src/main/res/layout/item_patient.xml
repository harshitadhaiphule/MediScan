<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:elevation="4dp"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/patientImage"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_action_profile" />


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/patientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#3E3C3C"/>

            <TextView
                android:id="@+id/patientAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age: 30"
                android:textColor="#3E3C3C"/>

            <TextView
                android:id="@+id/patientCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Condition: Hypertension"
                android:textColor="#3E3C3C"/>

            <TextView
                android:id="@+id/patientLastVisit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last visit: Oct 15, 2024"
                android:textColor="#3E3C3C"/>

            <TextView
                android:id="@+id/patientPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone: +1 (555) 123-4567"
                android:textColor="#3E3C3C"/>
        </LinearLayout>

    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>